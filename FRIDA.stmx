	<isee:payoff_specs_list>
		<isee:payoff_specs name="Full Payoff" calibration="true" recompute_weights="true" compare_tolerance="0" compare_type="ls" compare_run="-1">
			<isee:payoff_element name="GDP.GDP[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Government.government_consumption[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Finance.total_investment[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Circular_Flow.private_consumption[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.GDP_per_person[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_0_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_1_to_20_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_20_to_40_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_40_to_60_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_60_to_80_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.Aged_Over_80_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
			<isee:payoff_element name="Population.deaths_0_years[1]" weight="0">
				<isee:time_range type="terminal_value"/>
			</isee:payoff_element>
